# Supabase project settings (Project Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Used to build OAuth/email redirect URLs. Set to your deployed domain in
# production (e.g. https://ivy-hive.app); safe to leave unset in local dev,
# the code falls back to the request's own origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
